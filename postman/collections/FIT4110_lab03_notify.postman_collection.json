      "name": "01_Functional",
      "item": [
        {
          "name": "HealthCheck",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code phải là 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Cấu trúc phản hồi HealthStatus chính xác\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"status\", \"ok\");\r",
                  "    pm.expect(json).to.have.property(\"service\", \"notification-service\");\r",
                  "    pm.expect(json).to.have.property(\"time\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
